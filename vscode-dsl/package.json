{
  "name": "tasknet",
  "displayName": "TaskNet",
  "description": "TaskNet supports programming of MEXEC tasknets.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "publisher": "tasknet",
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "tasknet",
